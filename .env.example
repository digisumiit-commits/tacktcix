# TACKTCIX — Company Creation & Onboarding Engine
# Copy to .env and fill in values

# PostgreSQL
TACKTCIX_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tacktcix

# Neo4j
TACKTCIX_NEO4J_URI=bolt://localhost:7687
TACKTCIX_NEO4J_USER=neo4j
TACKTCIX_NEO4J_PASSWORD=password

# Qdrant
TACKTCIX_QDRANT_URL=http://localhost:6333

# Redis
TACKTCIX_REDIS_URL=redis://localhost:6379/0

# AI Model (DeepSeek)
TACKTCIX_AI_MODEL_API_KEY=
TACKTCIX_AI_MODEL_BASE_URL=https://api.deepseek.com/v1
TACKTCIX_DEFAULT_MODEL=deepseek-chat
