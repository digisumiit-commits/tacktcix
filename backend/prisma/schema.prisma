generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  FOUNDER
  ADMIN
  DEVELOPER
  OPERATOR
  OBSERVER
}

enum TeamRole {
  LEAD
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  name         String
  avatarUrl    String?

  googleId String? @unique
  githubId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgMemberships OrganizationMember[]
  teamMemberships TeamMember[]
  workspaceMemberships WorkspaceMember[]
  sentInvites     Invite[]         @relation("InvitedBy")
  refreshTokens   RefreshToken[]
  createdOrgs     Organization[]   @relation("OrgCreator")
  createdTeams    Team[]           @relation("TeamCreator")
  createdWorkspaces Workspace[]    @relation("WorkspaceCreator")
  subscription    Subscription?
  wallet          Wallet?
  usageRecords    UsageRecord[]
  invoices        Invoice[]
  autoRechargeConfig AutoRechargeConfig?
  requestedApprovals Approval[]       @relation("ApprovalRequester")
  decidedApprovals   Approval[]       @relation("ApprovalDecider")

  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User                @relation("OrgCreator", fields: [createdById], references: [id])
  members   OrganizationMember[]
  teams     Team[]
  workspaces Workspace[]
  invites   Invite[]
  approvals Approval[]

  @@map("organizations")
}

model OrganizationMember {
  id       String   @id @default(uuid())
  orgId    String
  userId   String
  role     OrgRole  @default(DEVELOPER)
  joinedAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("organization_members")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  orgId       String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy  User         @relation("TeamCreator", fields: [createdById], references: [id])
  members    TeamMember[]
  workspaces Workspace[]
  invites    Invite[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  orgId       String
  teamId      String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team      Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy User         @relation("WorkspaceCreator", fields: [createdById], references: [id])
  members   WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id        String   @id @default(uuid())
  workspaceId String
  userId    String
  joinedAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Invite {
  id          String       @id @default(uuid())
  email       String
  orgId       String
  teamId      String?
  role        OrgRole      @default(DEVELOPER)
  token       String       @unique
  status      InviteStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team      Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedBy User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@map("invites")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ── Billing ────────────────────────────────────────────────────

enum BillingPlanInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  TRIALING
}

enum TransactionType {
  CREDIT_PURCHASE
  CREDIT_BONUS
  AUTO_RECHARGE
  USAGE_DEDUCTION
  REFUND
  MANUAL_ADJUSTMENT
}

enum ResourceType {
  TOKENS
  BROWSER_RUNTIME
  STORAGE
  VECTOR_DB
  EXECUTION_TIME
  DEPLOYMENT
}

model BillingPlan {
  id            String              @id @default(uuid())
  name          String
  description   String?
  interval      BillingPlanInterval @default(MONTHLY)
  basePriceCents Int                 @default(0)
  includedCredits Int               @default(0)
  isPublic      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  subscriptions Subscription[]

  @@map("billing_plans")
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String
  planId            String
  status            SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  canceledAt         DateTime?
  autoRechargeEnabled Boolean          @default(false)
  autoRechargeAmountCents Int          @default(0)
  autoRechargeThresholdCredits Int     @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan  BillingPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@unique([userId])
  @@map("subscriptions")
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  creditBalance Int      @default(0)
  lifetimeCreditsAdded Int @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@map("wallets")
}

model CreditTransaction {
  id           String          @id @default(uuid())
  walletId     String
  amountCredits Int
  type         TransactionType
  description  String?
  idempotencyKey String?       @unique
  metadata     Json?
  createdAt    DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

model UsageRecord {
  id           String       @id @default(uuid())
  userId       String
  resource     ResourceType
  amount       Float
  unit         String
  costCredits  Int          @default(0)
  description  String?
  recordedAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId, resource])
  @@map("usage_records")
}

model Invoice {
  id            String    @id @default(uuid())
  userId        String
  subscriptionId String?
  periodStart   DateTime
  periodEnd     DateTime
  subtotalCents Int
  taxCents      Int       @default(0)
  totalCents    Int
  status        String    @default("open")
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?   @relation(fields: [subscriptionId], references: [id])
  lineItems    InvoiceLineItem[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  resource    ResourceType
  quantity    Float
  unitPriceCents Int
  totalCents  Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model PricingRule {
  id              String       @id @default(uuid())
  resource        ResourceType
  unit            String
  creditsPerUnit  Float
  effectiveFrom   DateTime     @default(now())
  effectiveUntil  DateTime?

  @@map("pricing_rules")
}

// ── Approvals ────────────────────────────────────────────────────

enum ApprovalType {
  ACCESS
  CREDIT
  INVITE
  ROLE_CHANGE
  AGENT_ACTION
  BILLING
}

enum ApprovalRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  CHANGES_REQUESTED
  EXPIRED
  CANCELED
}

model Approval {
  id            String         @id @default(uuid())
  orgId         String
  workspaceId   String?
  type          ApprovalType
  risk          ApprovalRisk   @default(LOW)
  status        ApprovalStatus @default(PENDING)
  title         String
  description   String?
  requestedById String
  metadata      Json?
  expiresAt     DateTime?

  decidedById   String?
  decision      String?
  decisionNote  String?
  decidedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspace   Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  requestedBy User                @relation("ApprovalRequester", fields: [requestedById], references: [id])
  decidedBy   User?               @relation("ApprovalDecider", fields: [decidedById], references: [id])
  activity    ApprovalActivity[]

  @@index([orgId, status])
  @@index([requestedById])
  @@index([type, status])
  @@map("approvals")
}

model ApprovalActivity {
  id         String   @id @default(uuid())
  approvalId String
  userId     String
  action     String
  note       String?
  createdAt  DateTime @default(now())

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([approvalId, createdAt])
  @@map("approval_activities")
}

model AutoRechargeConfig {
  id                      String  @id @default(uuid())
  userId                  String  @unique
  enabled                 Boolean @default(false)
  rechargeAmountCredits   Int     @default(1000)
  thresholdCredits        Int     @default(100)
  maxRechargesPerMonth    Int     @default(5)
  rechargeCountThisMonth  Int     @default(0)
  lastRechargeAt          DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auto_recharge_configs")
}
